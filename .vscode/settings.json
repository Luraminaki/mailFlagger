{
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "*.egg-info": true,
        "*.venv": true
    },
    "breadcrumbs.enabled": true,
    "editor.formatOnSave": false,
    "git.autofetch": true,
